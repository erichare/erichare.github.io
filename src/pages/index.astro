---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';

const projects = await getCollection('projects');
const projectById = new Map(projects.map((project) => [project.id, project]));

const featured = [
  {
    id: 'langflow',
    index: '01',
    label: 'Co-lead',
    responsiveHero: '/img/home/langflow-flow-700.webp',
    responsiveHeroSrcSet: '/img/home/langflow-flow-700.webp 700w, /img/home/langflow-flow-800.webp 800w, /img/home/langflow-flow.webp 1600w',
    description: 'I help shape Langflow at IBM, with a focus on agent tooling, MCP, the SDK, and the production details that make open-source software dependable.',
    caption: 'Langflow’s visual canvas turns an agent system into an inspectable flow.',
  },
  {
    id: 'verity',
    index: '02',
    label: 'Creator',
    responsiveHero: '/img/home/verity-surface-700.webp',
    responsiveHeroSrcSet: '/img/home/verity-surface-700.webp 700w, /img/home/verity-surface-800.webp 800w, /img/home/verity-surface.webp 1600w',
    description: 'An open forensic-comparison engine that reports calibrated evidentiary strength instead of hiding uncertainty behind a binary match.',
    caption: 'Three-dimensional surface evidence and aligned crosscut signatures in Bullet Lens.',
  },
  {
    id: 'aeroza',
    index: '03',
    label: 'Creator',
    responsiveHero: '/img/home/aeroza-radar-700.webp',
    responsiveHeroSrcSet: '/img/home/aeroza-radar-700.webp 700w, /img/home/aeroza-radar-800.webp 800w, /img/home/aeroza-radar.webp 1600w',
    description: 'A developer-first weather platform for live radar, geospatial queries, streaming APIs, signed alerts, and public forecast verification.',
    caption: 'Live radar and severe-weather context exposed through one queryable platform.',
  },
].map((item) => ({ ...item, project: projectById.get(item.id)! }));

const supporting = [
  {
    id: 'astra-data-api',
    image: '/img/home/astra-data-api-160.webp',
    srcSet: '/img/home/astra-data-api-160.webp 160w, /img/home/astra-data-api-320.webp 320w',
    sizes: '10rem',
    alt: 'Astra DB Data API mark.',
    detail: 'The HTTP and JSON data plane behind Langflow, ingestion, and the astrapy client.',
  },
  {
    id: 'ai-workbench',
    image: '/img/home/ai-workbench-640.webp',
    srcSet: '/img/home/ai-workbench-640.webp 640w, /img/home/ai-workbench-700.webp 700w, /img/home/ai-workbench.webp 1200w',
    sizes: '(max-width: 900px) calc(100vw - 2.5rem), 20rem',
    alt: 'AI Workbench workspace with knowledge bases and agents.',
    detail: 'A self-hosted workspace for building, inspecting, and operating retrieval-backed AI applications.',
  },
].map((item) => ({ ...item, project: projectById.get(item.id)! }));

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <section class="home-hero">
    <div class="container-wide home-hero__inner">
      <img
        src="/img/home/hero-evidence-map-900.webp"
        alt=""
        width="900"
        height="600"
        class="home-hero__art"
        aria-hidden="true"
      />
      <div class="home-hero__copy">
        <p class="eyebrow">Software engineer · statistician</p>
        <h1>I build tools for decisions you can inspect.</h1>
        <p class="home-hero__lede">
          Software engineer and statistician. Core Langflow maintainer at IBM; creator of Verity and Aeroza.
        </p>
        <div class="home-hero__actions">
          <a href="#selected-work" class="button button-primary">
            Explore selected work <Icon name="ph:arrow-right" width="16" />
          </a>
          <a href="/blog" class="button button-secondary">Read the writing</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide proof-strip" aria-label="A short professional profile">
    <div>
      <p class="eyebrow">At IBM</p>
      <p>Core Langflow maintainer. Building agent tooling used in production.</p>
    </div>
    <div>
      <p class="eyebrow">Open source</p>
      <p>Creator of Verity and Aeroza. Open, transparent, community-first.</p>
    </div>
    <div>
      <p class="eyebrow">Statistical rigor</p>
      <p>PhD in Statistics &amp; Computer Science. Forensic methods and reproducible analysis.</p>
    </div>
    <div>
      <p class="eyebrow">Location &amp; time</p>
      <p>Lake Stevens, Washington. Working across software, data, and decisions.</p>
    </div>
  </section>

  <section id="selected-work" class="container-wide home-work">
    <div class="home-section-heading">
      <p class="eyebrow">Selected work</p>
      <h2>Systems built to hold up under scrutiny.</h2>
    </div>

    <div class="feature-list">
      {featured.map(({ project, index, label, responsiveHero, responsiveHeroSrcSet, description, caption }) => (
        <article class="feature-project">
          <div class="feature-project__index" aria-hidden="true">{index}</div>
          <div class="feature-project__copy">
            <p class="eyebrow">{label}</p>
            <h3>{project.data.title}</h3>
            <p class="feature-project__tagline">{project.data.tagline}</p>
            <p>{description}</p>
            <a href={`/projects/${project.id}`} class="feature-project__link">
              Explore {project.data.title} <Icon name="ph:arrow-right" width="16" />
            </a>
          </div>
          <figure class="feature-project__media">
            <img
              src={responsiveHero}
              srcset={responsiveHeroSrcSet}
              sizes="(max-width: 900px) calc(100vw - 5.5rem), 43rem"
              alt={project.data.heroAlt ?? ''}
              width="1600"
              height="820"
              loading="lazy"
              decoding="async"
            />
            <figcaption>{caption}</figcaption>
          </figure>
        </article>
      ))}
    </div>
  </section>

  <section class="container-wide supporting-work">
    <p class="eyebrow">Also helping build</p>
    <div class="supporting-work__grid">
      {supporting.map(({ project, image, srcSet, sizes, alt, detail }) => (
        <a href={`/projects/${project.id}`} class="supporting-project">
          <div class:list={['supporting-project__image', project.id === 'astra-data-api' && 'is-logo']}>
            <img src={image} srcset={srcSet} sizes={sizes} alt={alt} loading="lazy" decoding="async" />
          </div>
          <div>
            <h3>{project.data.title}</h3>
            <p>{detail}</p>
            <span>Learn more <Icon name="ph:arrow-right" width="14" /></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="container-wide home-writing">
    <div class="home-section-heading home-section-heading--row">
      <div>
        <p class="eyebrow">From the desk</p>
        <h2>Notes on evidence, agents, and uncertainty.</h2>
      </div>
      <a href="/blog" class="feature-project__link">All writing <Icon name="ph:arrow-right" width="15" /></a>
    </div>
    <ol class="writing-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>
            <div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
            <div class="writing-list__meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' })}
              </time>
              <span>{post.data.tags[0] ?? 'notes'}</span>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <section class="container-wide home-contact">
    <div>
      <p class="eyebrow">Let’s talk</p>
      <h2>Let’s build things that stand up to scrutiny.</h2>
      <p>I’m always up for a conversation about AI agents, developer platforms, statistical graphics, or forensic statistics.</p>
    </div>
    <div class="home-contact__links">
      <a href={`mailto:${SITE.email}`}><Icon name="ph:envelope-simple" width="18" /> {SITE.email}</a>
      <a href={SITE.social.github}><Icon name="simple-icons:github" width="16" /> github.com/erichare</a>
      <a href={SITE.social.linkedin}><Icon name="simple-icons:linkedin" width="16" /> LinkedIn</a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    overflow: hidden;
    border-bottom: 1px solid var(--color-border-muted);
  }

  .home-hero__inner {
    position: relative;
    display: grid;
    min-height: 38rem;
    align-items: center;
    padding-block: 6.5rem 5.5rem;
  }

  .home-hero__copy {
    position: relative;
    z-index: 1;
    max-width: 49rem;
  }

  .home-hero h1 {
    max-width: 48rem;
    margin-top: 1.2rem;
    font-size: clamp(4rem, 8vw, 7rem);
    line-height: 0.92;
  }

  .home-hero__lede {
    max-width: 39rem;
    margin-top: 1.65rem;
    color: var(--color-fg-muted);
    font-size: clamp(1.05rem, 2vw, 1.28rem);
    line-height: 1.55;
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.8rem;
  }

  .home-hero__art {
    position: absolute;
    top: 0;
    right: -12rem;
    width: min(70vw, 52rem);
    height: 100%;
    object-fit: cover;
    object-position: right center;
    opacity: 0.75;
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  :global(:root[data-theme='dark']) .home-hero__art {
    filter: invert(1);
    opacity: 0.14;
    mix-blend-mode: screen;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
    padding-block: 2.25rem;
    border-bottom: 1px solid var(--color-border-muted);
  }

  .proof-strip p:last-child {
    margin-top: 0.7rem;
    color: var(--color-fg-muted);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .home-work,
  .supporting-work,
  .home-writing {
    padding-block: 4.75rem;
    border-bottom: 1px solid var(--color-border-muted);
  }

  .home-section-heading {
    display: grid;
    grid-template-columns: minmax(8rem, 0.25fr) minmax(0, 1fr);
    gap: 2.5rem;
    align-items: start;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border-muted);
  }

  .home-section-heading h2 {
    max-width: 45rem;
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    line-height: 0.98;
  }

  .feature-project {
    display: grid;
    grid-template-columns: 3.5rem minmax(13rem, 0.52fr) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: stretch;
    padding-block: 2rem;
    border-bottom: 1px solid var(--color-border-muted);
  }

  .feature-project__index {
    color: var(--color-accent);
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .feature-project__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-right: 1rem;
  }

  .feature-project h3 {
    margin-top: 0.8rem;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 1;
  }

  .feature-project__tagline {
    margin-top: 1rem;
    color: var(--color-fg);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.55;
  }

  .feature-project__copy > p:not(.eyebrow):not(.feature-project__tagline) {
    margin-top: 0.8rem;
    color: var(--color-fg-muted);
    font-size: 0.83rem;
    line-height: 1.6;
  }

  .feature-project__link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 1.2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 55%, transparent);
    color: var(--color-accent-strong);
    font-size: 0.8rem;
    font-weight: 550;
  }

  .feature-project__link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .feature-project__media img {
    width: 100%;
    aspect-ratio: 1.95 / 1;
    object-fit: cover;
    border: 1px solid var(--color-border-muted);
    background: var(--color-bg-elev);
  }

  .feature-project__media figcaption {
    margin-top: 0.5rem;
    color: var(--color-fg-subtle);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    line-height: 1.45;
  }

  .supporting-work > .eyebrow {
    margin-bottom: 1.25rem;
  }

  .supporting-work__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--color-border-muted);
  }

  .supporting-project {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.25rem;
    padding: 1.25rem;
    border-bottom: 1px solid var(--color-border-muted);
  }

  .supporting-project:first-child {
    border-right: 1px solid var(--color-border-muted);
  }

  .supporting-project:hover {
    background: var(--color-accent-soft);
  }

  .supporting-project__image {
    overflow: hidden;
    align-self: stretch;
    min-height: 6.5rem;
    background: var(--color-bg-elev);
  }

  .supporting-project__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .supporting-project__image.is-logo {
    display: grid;
    place-items: center;
    background: #101714;
  }

  .supporting-project__image.is-logo img {
    width: 5rem;
    height: 5rem;
    object-fit: contain;
  }

  .supporting-project h3 {
    font-size: 1.35rem;
  }

  .supporting-project p {
    margin-top: 0.45rem;
    color: var(--color-fg-muted);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .supporting-project span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 550;
  }

  .home-section-heading--row {
    grid-template-columns: 1fr auto;
    align-items: end;
  }

  .home-section-heading--row > div h2 {
    margin-top: 0.8rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .writing-list li {
    border-bottom: 1px solid var(--color-border-muted);
  }

  .writing-list a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
    padding-block: 1.25rem;
  }

  .writing-list a:hover h3 {
    color: var(--color-accent);
  }

  .writing-list h3 {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .writing-list p {
    max-width: 48rem;
    margin-top: 0.3rem;
    color: var(--color-fg-muted);
    font-size: 0.77rem;
    line-height: 1.5;
  }

  .writing-list__meta {
    display: grid;
    min-width: 9rem;
    grid-template-columns: 1fr;
    gap: 0.3rem;
    text-align: right;
    color: var(--color-fg-subtle);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .home-contact {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(15rem, 0.6fr);
    gap: 3rem;
    align-items: center;
    margin-top: 4.75rem;
    padding: 2.75rem 3rem;
    border-left: 4px solid var(--color-signal);
    background: var(--color-accent-soft);
  }

  .home-contact h2 {
    max-width: 42rem;
    margin-top: 0.8rem;
    font-size: clamp(2rem, 4vw, 3.3rem);
    line-height: 1;
  }

  .home-contact p:not(.eyebrow) {
    max-width: 42rem;
    margin-top: 0.8rem;
    color: var(--color-fg-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .home-contact__links {
    display: grid;
    gap: 0.75rem;
  }

  .home-contact__links a {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.65rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    font-size: 0.78rem;
  }

  .home-contact__links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .home-hero__art {
      right: -22rem;
      width: 58rem;
      opacity: 0.45;
    }

    .proof-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .feature-project {
      grid-template-columns: 3rem minmax(0, 1fr);
    }

    .feature-project__media {
      grid-column: 2;
      margin-top: 0.5rem;
    }

    .supporting-work__grid {
      grid-template-columns: 1fr;
    }

    .supporting-project:first-child {
      border-right: 0;
    }
  }

  @media (max-width: 640px) {
    .home-hero__inner {
      min-height: auto;
      padding-block: 4.75rem 4rem;
    }

    .home-hero h1 {
      font-size: clamp(3.4rem, 17vw, 5.2rem);
    }

    .home-hero__art {
      right: -25rem;
      width: 50rem;
      opacity: 0.22;
    }

    .proof-strip {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .home-section-heading,
    .home-section-heading--row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .feature-project {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .feature-project__media {
      grid-column: 1;
    }

    .feature-project__copy {
      padding-right: 0;
    }

    .feature-project__link {
      margin-top: 0.25rem;
    }

    .supporting-project {
      grid-template-columns: 1fr;
      padding-inline: 0;
    }

    .supporting-project__image {
      min-height: 10rem;
    }

    .writing-list a {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .writing-list__meta {
      grid-template-columns: auto auto;
      justify-content: start;
      text-align: left;
    }

    .home-contact {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      margin-top: 3.5rem;
      padding: 2rem 1.5rem;
    }
  }
</style>
