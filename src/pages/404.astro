---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="That page doesn't exist.">
  <section class="container-wide py-32 text-center">
    <p class="text-xs uppercase tracking-[0.18em] font-mono mb-4" style="color: var(--color-accent);">404</p>
    <h1 class="text-5xl md:text-6xl font-semibold" style="font-family: var(--font-serif); font-weight: 500;">
      Nothing to see here.
    </h1>
    <p class="mt-4 max-w-md mx-auto" style="color: var(--color-fg-muted);">
      The page you asked for isn't here. It may have moved in the redesign — try the
      <a href="/" class="link">home page</a>, the <a href="/projects" class="link">projects</a>,
      or the <a href="/blog" class="link">writing</a>.
    </p>
  </section>
</BaseLayout>
