---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';

const timeline = [
  {
    period: '2025 — Present',
    role: 'Software Engineer',
    org: 'IBM',
    detail: 'Core Langflow maintainer on Developer and Operator Experience. I work across MCP, the Langflow SDK, agent tool-use policy, model providers, retrieval tooling, and the production seams users feel first.',
  },
  {
    period: '2022 — 2025',
    role: 'Software Engineer',
    org: 'DataStax',
    detail: 'Built Astra DB and GenAI product surfaces, then joined the Langflow core team after DataStax acquired the project in 2024. Moved with DataStax into IBM in 2025.',
  },
  {
    period: '2021 — 2022',
    role: 'Senior Data Scientist',
    org: 'Daisi Technology',
    detail: 'Built serverless Python functions for scientific computing and wrote much of the platform’s engineering story.',
  },
  {
    period: '2017 — 2021',
    role: 'Chief Data Scientist',
    org: 'Omni Analytics Group',
    detail: 'Led statistical consulting, Shiny application work, and technical teaching. Helped seed the open-source OmniacsDAO suite.',
  },
  {
    period: '2012 — 2017',
    role: 'PhD, Statistics & Computer Science',
    org: 'Iowa State University',
    detail: 'Developed reproducible methods for forensic bullet comparison with CSAFE and shipped the work as papers, R packages, and a dissertation.',
  },
];

const principles = [
  { icon: 'ph:magnifying-glass', title: 'Inspectability', body: 'A useful system should show its reasoning, state, and failure modes.' },
  { icon: 'ph:scales', title: 'Honest evaluation', body: 'Measure uncertainty and publish the misses, not only the attractive examples.' },
  { icon: 'ph:package', title: 'Open implementation', body: 'Good research and good developer experience both improve when the code can be run.' },
  { icon: 'ph:flow-arrow', title: 'Agent tooling', body: 'MCP, orchestration, policy, and the infrastructure underneath a reliable tool call.' },
  { icon: 'ph:chart-line', title: 'Statistical graphics', body: 'Interfaces that help people reason about variation rather than hide it.' },
  { icon: 'ph:graduation-cap', title: 'Teaching', body: 'The best technical explanation leaves someone able to do the next step alone.' },
];
---

<BaseLayout title="About" description="Eric Hare — software engineer, statistician, open-source maintainer, and forensic statistics researcher.">
  <PageHeader
    eyebrow="About"
    title="Software engineer by way of statistics."
    lede="I build open tools for agents, data, and evidence—and I care whether the decisions they support can be inspected, reproduced, and challenged."
  />

  <Section>
    <div class="about-intro">
      <div class="prose-styled">
        <p>
          I’m a software engineer at <strong>IBM</strong> on the Developer and Operator Experience team,
          where I’m a core maintainer of <a href="https://github.com/langflow-ai/langflow">Langflow</a>.
          My work sits at the boundary between the clean API a developer wants and the messy production
          system that has to keep working: agent tools, MCP, authentication, model providers, retrieval,
          packaging, SDKs, and release pipelines.
        </p>
        <p>
          Before agents, I worked on statistical evidence. I earned dual undergraduate degrees in
          Statistics and Computer Engineering from the University of Washington, then a PhD in Statistics
          and Computer Science at Iowa State. My dissertation developed reproducible methods for comparing
          3D scans of spent bullets. That research now has a second life in
          <a href="/projects/verity">Verity</a>, an open engine for calibrated forensic surface comparison.
        </p>
        <p>
          I also build <a href="/projects/aeroza">Aeroza</a>, a weather platform organized around a similar
          idea: forecasts should be queryable, testable, and scored against what actually happened. The
          domains are different; the instinct is the same.
        </p>
        <p>
          I live north of Seattle with my partner and our two cats. Away from the terminal, I’m usually
          gaming, following Pacific Northwest weather, or convincing myself that one more side project is
          a reasonable way to spend a weekend.
        </p>
      </div>

      <aside class="about-portrait">
        <Image
          src="/img/personal/personal-image.jpg"
          alt="Eric Hare"
          width={460}
          height={460}
          loading="eager"
        />
        <dl>
          <div><dt>Based in</dt><dd>Lake Stevens, WA</dd></div>
          <div><dt>Current role</dt><dd>Software Engineer, IBM</dd></div>
          <div><dt>Contact</dt><dd><a href="mailto:ericrhare@gmail.com">ericrhare@gmail.com</a></dd></div>
        </dl>
      </aside>
    </div>
  </Section>

  <Section eyebrow="Principles" title="What carries across the work.">
    <div class="principle-grid">
      {principles.map((principle) => (
        <article>
          <Icon name={principle.icon} width="21" />
          <h3>{principle.title}</h3>
          <p>{principle.body}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section eyebrow="Timeline" title="The short chronology.">
    <ol class="career-list">
      {timeline.map((item) => (
        <li>
          <p class="career-list__period">{item.period}</p>
          <div>
            <h3>{item.role} <span>— {item.org}</span></h3>
            <p>{item.detail}</p>
          </div>
        </li>
      ))}
    </ol>
    <a href="/cv" class="timeline-link">Read the full CV <Icon name="ph:arrow-right" width="16" /></a>
  </Section>
</BaseLayout>

<style>
  .about-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: 5rem;
    align-items: start;
  }

  .about-portrait {
    border-top: 1px solid var(--color-border-muted);
    padding-top: 0.75rem;
  }

  .about-portrait img {
    width: 100%;
    filter: saturate(0.72) contrast(1.02);
  }

  .about-portrait dl {
    margin-top: 1rem;
  }

  .about-portrait dl > div {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.75rem;
    padding-block: 0.75rem;
    border-bottom: 1px solid var(--color-border-muted);
    font-size: 0.74rem;
  }

  .about-portrait dt {
    color: var(--color-fg-subtle);
    font-family: var(--font-mono);
    font-size: 0.59rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .about-portrait dd,
  .about-portrait a {
    color: var(--color-fg-muted);
  }

  .principle-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--color-border-muted);
  }

  .principle-grid article {
    min-height: 12rem;
    padding: 1.5rem;
    border-right: 1px solid var(--color-border-muted);
    border-bottom: 1px solid var(--color-border-muted);
  }

  .principle-grid article:nth-child(3n) {
    border-right: 0;
  }

  .principle-grid svg {
    color: var(--color-accent);
  }

  .principle-grid h3 {
    margin-top: 1.3rem;
    font-size: 1.55rem;
  }

  .principle-grid p {
    margin-top: 0.55rem;
    color: var(--color-fg-muted);
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .career-list {
    border-top: 1px solid var(--color-border-muted);
  }

  .career-list li {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr);
    gap: 2rem;
    padding-block: 1.4rem;
    border-bottom: 1px solid var(--color-border-muted);
  }

  .career-list__period {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .career-list h3 {
    font-size: 1.45rem;
  }

  .career-list h3 span {
    color: var(--color-fg-muted);
    font-weight: 400;
  }

  .career-list div p {
    max-width: 45rem;
    margin-top: 0.5rem;
    color: var(--color-fg-muted);
    font-size: 0.83rem;
    line-height: 1.65;
  }

  .timeline-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1.5rem;
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 550;
  }

  @media (max-width: 780px) {
    .about-intro {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about-portrait {
      max-width: 22rem;
    }

    .principle-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .principle-grid article:nth-child(3n) {
      border-right: 1px solid var(--color-border-muted);
    }

    .principle-grid article:nth-child(2n) {
      border-right: 0;
    }
  }

  @media (max-width: 540px) {
    .principle-grid {
      grid-template-columns: 1fr;
    }

    .principle-grid article {
      min-height: auto;
      border-right: 0 !important;
    }

    .career-list li {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }
  }
</style>
