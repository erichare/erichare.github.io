---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Section from '../../components/Section.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout title="Writing" description="Essays and notes by Eric Hare on AI engineering, data science, statistical graphics, and open-source maintenance.">
  <PageHeader
    eyebrow="Writing"
    title="Notes, essays, and field reports."
    lede="Mostly about what I'm working on — AI agent tooling, MCP, R packaging, and the occasional statistical aside."
  />

  <Section>
    <ul class="space-y-10 max-w-3xl">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="block group">
            <time
              class="text-xs font-mono"
              style="color: var(--color-fg-subtle);"
              datetime={post.data.pubDate.toISOString()}
            >
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <h2 class="mt-1 text-2xl font-medium group-hover:text-[var(--color-accent)] transition" style="font-family: var(--font-serif); font-weight: 500;">
              {post.data.title}
            </h2>
            <p class="mt-2 leading-relaxed" style="color: var(--color-fg-muted);">
              {post.data.description}
            </p>
            {post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {post.data.tags.map((t) => <span class="chip">#{t}</span>)}
              </div>
            )}
          </a>
        </li>
      ))}
      {posts.length === 0 && (
        <li style="color: var(--color-fg-muted);">No posts yet — come back soon.</li>
      )}
    </ul>
  </Section>
</BaseLayout>
