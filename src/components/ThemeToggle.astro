---
import { Icon } from 'astro-icon/components';
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Switch to dark theme"
  class="icon-button theme-toggle"
>
  <Icon name="ph:sun" width="19" class="theme-icon-light" aria-hidden="true" />
  <Icon name="ph:moon" width="19" class="theme-icon-dark hidden" aria-hidden="true" />
  <span class="sr-only theme-toggle__state">Light theme active</span>
</button>

<script is:inline>
  (function () {
    const KEY = 'eh-theme';
    const root = document.documentElement;
    const button = document.getElementById('theme-toggle');
    if (!button || button.dataset.bound === 'true') return;
    button.dataset.bound = 'true';

    const sync = () => {
      const dark = root.dataset.theme === 'dark';
      button.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
      button.querySelector('.theme-icon-light')?.classList.toggle('hidden', dark);
      button.querySelector('.theme-icon-dark')?.classList.toggle('hidden', !dark);
      const state = button.querySelector('.theme-toggle__state');
      if (state) state.textContent = dark ? 'Dark theme active' : 'Light theme active';
    };

    sync();
    button.addEventListener('click', () => {
      const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      localStorage.setItem(KEY, next);
      sync();
    });
  })();
</script>
