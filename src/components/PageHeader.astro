---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---

<section class="page-header">
  <div class="container-wide page-header__grid">
    <div>{eyebrow && <p class="eyebrow">{eyebrow}</p>}</div>
    <div>
      <h1 class="page-header__title">{title}</h1>
      {lede && <p class="page-header__lede">{lede}</p>}
    </div>
  </div>
</section>
