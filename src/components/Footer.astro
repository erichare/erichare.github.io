---
import { SITE } from '../lib/site';
import { Icon } from 'astro-icon/components';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t" style="border-color: var(--color-border-muted);">
  <div class="container-wide py-10 flex flex-col gap-6 md:flex-row md:justify-between md:items-center text-sm" style="color: var(--color-fg-muted);">
    <div class="flex flex-col gap-1">
      <p>&copy; {year} {SITE.author}. Built with Astro, deployed on GitHub Pages.</p>
      <p class="text-xs" style="color: var(--color-fg-subtle);">
        <a href="/llms.txt" class="link">llms.txt</a>
        <span class="mx-1.5">·</span>
        <a href="/rss.xml" class="link">RSS</a>
        <span class="mx-1.5">·</span>
        <a href={`https://github.com/erichare/erichare.github.io`} class="link">Source</a>
      </p>
    </div>
    <div class="flex items-center gap-3">
      <a href={SITE.social.github} aria-label="GitHub" class="p-2 rounded-md hover:opacity-80 transition" style="color: var(--color-fg-muted);">
        <Icon name="simple-icons:github" width="18" />
      </a>
      <a href={SITE.social.linkedin} aria-label="LinkedIn" class="p-2 rounded-md hover:opacity-80 transition" style="color: var(--color-fg-muted);">
        <Icon name="simple-icons:linkedin" width="18" />
      </a>
      <a href={SITE.social.scholar} aria-label="Google Scholar" class="p-2 rounded-md hover:opacity-80 transition" style="color: var(--color-fg-muted);">
        <Icon name="simple-icons:googlescholar" width="18" />
      </a>
      <a href={`mailto:${SITE.email}`} aria-label="Email" class="p-2 rounded-md hover:opacity-80 transition" style="color: var(--color-fg-muted);">
        <Icon name="lucide:mail" width="18" />
      </a>
      <a href="/rss.xml" aria-label="RSS feed" class="p-2 rounded-md hover:opacity-80 transition" style="color: var(--color-fg-muted);">
        <Icon name="lucide:rss" width="18" />
      </a>
    </div>
  </div>
</footer>
