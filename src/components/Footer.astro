---
import { Icon } from 'astro-icon/components';
import { SITE } from '../lib/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide site-footer__inner">
    <div>
      <a href="/" class="site-mark site-footer__mark">
        <span class="site-mark__dot" aria-hidden="true"></span>
        <span>{SITE.name}</span>
      </a>
      <p class="site-footer__note">Software engineer and statistician in Lake Stevens, Washington.</p>
    </div>

    <nav class="site-footer__links" aria-label="Footer">
      <a href="/publications">Publications</a>
      <a href="/now">Now</a>
      <a href="/rss.xml">RSS</a>
      <a href="/llms.txt">llms.txt</a>
      <a href="https://github.com/erichare/erichare.github.io">Source</a>
    </nav>

    <div class="site-footer__social">
      <a href={SITE.social.github} aria-label="GitHub"><Icon name="simple-icons:github" width="17" /></a>
      <a href={SITE.social.linkedin} aria-label="LinkedIn"><Icon name="simple-icons:linkedin" width="17" /></a>
      <a href={SITE.social.scholar} aria-label="Google Scholar"><Icon name="simple-icons:googlescholar" width="17" /></a>
      <a href={`mailto:${SITE.email}`} aria-label="Email"><Icon name="ph:envelope-simple" width="19" /></a>
    </div>
  </div>
  <div class="container-wide site-footer__meta">
    <span>&copy; {year} {SITE.author}</span>
    <span>Built with Astro. Deployed on GitHub Pages.</span>
  </div>
</footer>
