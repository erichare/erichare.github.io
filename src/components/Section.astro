---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  class?: string;
}
const { id, eyebrow, title, subtitle, class: className = '' } = Astro.props;
---

<section id={id} class:list={['container-wide py-14 md:py-20', className]}>
  {eyebrow && (
    <p class="text-xs uppercase tracking-[0.18em] font-mono mb-3" style="color: var(--color-accent);">
      {eyebrow}
    </p>
  )}
  {title && (
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight max-w-2xl" style="font-family: var(--font-serif); font-weight: 500;">
      {title}
    </h2>
  )}
  {subtitle && (
    <p class="mt-3 max-w-2xl" style="color: var(--color-fg-muted);">{subtitle}</p>
  )}
  <div class:list={[title || eyebrow ? 'mt-8 md:mt-10' : '']}>
    <slot />
  </div>
</section>
