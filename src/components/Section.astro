---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  class?: string;
}
const { id, eyebrow, title, subtitle, class: className = '' } = Astro.props;
---

<section id={id} class:list={['container-wide section-block', className]}>
  {(eyebrow || title || subtitle) && (
    <div class="section-heading">
      <div>{eyebrow && <p class="eyebrow">{eyebrow}</p>}</div>
      <div>
        {title && <h2 class="section-heading__title">{title}</h2>}
        {subtitle && <p class="section-heading__subtitle">{subtitle}</p>}
      </div>
    </div>
  )}
  <div class:list={[title || eyebrow || subtitle ? 'section-content' : '']}>
    <slot />
  </div>
</section>
